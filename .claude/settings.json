{
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "NotebookEdit",
      "WebSearch",
      "WebFetch",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git rev-parse)",
      "Bash(git rev-parse *)",
      "Bash(git branch)",
      "Bash(git branch --list *)",
      "Bash(git branch -r)",
      "Bash(git branch -r *)",
      "Bash(git branch -a)",
      "Bash(git branch -v)",
      "Bash(git branch -vv)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git stash list *)",
      "mcp__ide__*",
      "mcp__chrome-devtools__*",
      "mcp__claude-in-chrome__*",
      "mcp__playwright__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(/secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.crt)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(/secrets/**)",
      "Write(./config/credentials.json)",
      "Write(./**/*.key)",
      "Write(./**/*.pem)",
      "Write(./**/*.crt)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "Bash(git tag *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git cherry-pick *)",
      "Bash(git am *)",
      "Bash(git apply *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git remote add *)",
      "Bash(git remote remove *)",
      "Bash(git remote set-url *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "shopify-plugin@shopify-ai-toolkit": true
  },
  "outputStyle": "Explanatory",
  "alwaysThinkingEnabled": false
}
